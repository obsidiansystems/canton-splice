data ExternalPartyAmuletRules_ExpireAmuletAllocationInput = ExternalPartyAmuletRules_ExpireAmuletAllocationInput
  with
    allocationCid : ContractId AmuletAllocation
    expireLock : Bool
  deriving (Eq, Show)

data ExternalPartyAmuletRules_ExpireAmuletAllocationsResult = ExternalPartyAmuletRules_ExpireAmuletAllocationsResult
  with
    results : [AmuletAllocation_DsoExpireResult]
  deriving (Eq, Show)

data ExternalPartyAmuletRules_ExpireAmuletAllocationsV2Result = ExternalPartyAmuletRules_ExpireAmuletAllocationsV2Result {}
  -- intentionally no results to save storage space in Scan
  deriving (Eq, Show)

-- | Rules contract that can be used in transactions that require signatures
-- from an external party. This is intended to get archived and recreated as rarely as possible
-- to support long delays between preparing and signing a transaction.
template ExternalPartyAmuletRules
  with
    dso : Party
  where
    signatory dso

    nonconsuming choice ExternalPartyAmuletRules_ExpireAmuletAllocations : ExternalPartyAmuletRules_ExpireAmuletAllocationsResult
      with
        expectedDso : Party
        inputs : [ExternalPartyAmuletRules_ExpireAmuletAllocationInput]
        observers : [Party]
      observer observers
      controller dso
      do
        requireMatchExpected ("expectedDso", expectedDso) dso

        results <- forA inputs $ \input -> do
          alloc <- fetchButArchiveLater (ForDso with dso) input.allocationCid
          requireMatchExpected ("allocation.transferLeg.instrumentId.admin", alloc.allocation.transferLeg.instrumentId.admin) dso
          exercise input.allocationCid AmuletAllocation_DsoExpire with
            expireLock = input.expireLock

        pure ExternalPartyAmuletRules_ExpireAmuletAllocationsResult with results

    nonconsuming choice ExternalPartyAmuletRules_ExpireAmuletAllocationsV2 : ExternalPartyAmuletRules_ExpireAmuletAllocationsV2Result
      with
        cancellations : [(ContractId V2.Allocation, V2.Allocation_Cancel)]
        observers : [Party]
      observer observers
      controller dso
      do
        forA_ cancellations $ \(allocCid, choiceArg) -> do
          -- prudent engineering: double-check the actors
          requireMatchExpected ("choiceArg.actors", choiceArg.actors) [dso]
          alloc <- fetchCheckedInterface @V2.Allocation (ForDso with dso) allocCid
          -- Only allow this call on expired allocations, so that it becomes safe to delegate it
          -- to any SV. Without this check a malicious SV could use this call to cancel any allocation
          -- that has the DSO party as the executor.
          case (view alloc).expiresAt of
            None -> fail "Cannot expire allocation without an expiry time"
            Some expiresAt -> do
              assertDeadlineExceeded "allocation.expiresAt" expiresAt
              exercise allocCid choiceArg

        pure ExternalPartyAmuletRules_ExpireAmuletAllocationsV2Result


    -- This choice is not guarded by any resource consumption other than the traffic required to pay for the submission of the exercising of this choice.
    -- If this is being abused the DSO party can blacklist (or rate limit) the submitting participant node.
    nonconsuming choice ExternalPartyAmuletRules_CreateTransferCommand : ExternalPartyAmuletRules_CreateTransferCommandResult
      with
        sender : Party
        receiver : Party
        delegate : Party
        amount : Decimal
        expiresAt : Time
        nonce : Int
        description : Optional Text
        expectedDso : Optional Party
        -- Party that the sender expects to represent the DSO party of the ExternalAmuletRules contract they are calling.
        -- Must always be set to protect from malicious delegees swapping the ExternalAmuletRules contract out for
        -- one under their control.
      controller sender
      do
         checkExpectedDso dso expectedDso
         assertWithinDeadline "ExternalPartyAmuletRules_CreateTransferCommand.expiresAt" expiresAt
         cmd <- create TransferCommand with
           dso
           sender
           receiver
           delegate
           amount
           expiresAt
           nonce
           description
         pure (ExternalPartyAmuletRules_CreateTransferCommandResult cmd)

    interface instance Api.Token.TransferInstructionV1.TransferFactory for ExternalPartyAmuletRules where
      view = Api.Token.TransferInstructionV1.TransferFactoryView with
        admin = dso
        meta = emptyMetadata

      transferFactory_transferImpl _self arg =
        amulet_transferFactoryV1_transferImpl this [arg.transfer.sender] arg
      transferFactory_publicFetchImpl = publicFetchDefaultImpl this

    interface instance V2.TransferFactory for ExternalPartyAmuletRules where
      view = V2.TransferFactoryView with
        admin = dso
        meta = emptyMetadata

      transferFactory_transferExtraObservers = transferFactoryV2_publicAsset_transferExtraObserversDefaultImpl

      transferFactory_transferImpl =
        transferFactoryV2_transferDefaultImplUsingV1 $ amulet_transferFactoryV1_transferImpl this

      transferFactory_publicFetchImpl = publicFetchDefaultImpl this


    interface instance V1.AllocationFactory for ExternalPartyAmuletRules where
      view = V1.AllocationFactoryView with
        admin = dso
        meta = emptyMetadata

      allocationFactory_allocateImpl self arg = amulet_allocationFactoryV1_allocateImpl this self arg
      allocationFactory_publicFetchImpl = publicFetchDefaultImpl this

    interface instance V2.AllocationFactory for ExternalPartyAmuletRules where
      view = V2.AllocationFactoryView with
        admin = dso
        meta = emptyMetadata

      allocationFactory_allocateExtraObservers = allocationFactoryV2_publicAsset_allocateExtraObserversDefaultImpl

      allocationFactory_allocateImpl self arg = amulet_allocationFactoryV2_allocateImpl this self arg
      allocationFactory_publicFetchImpl = publicFetchDefaultImpl this

    interface instance V2.SettlementFactory for ExternalPartyAmuletRules where
      view = V2.SettlementFactoryView with
        admin = dso
        meta = emptyMetadata

      settlementFactory_settleBatchImpl self arg = do
        -- No filtering required, as Amulet does not use any per-account information
        -- for batch settlement. Preapprovals are only used for transfers.
        let getFilteredExtraArgs _allocView settleArg = pure settleArg.extraArgs
        settlementFactoryV2_settleBatchDefaultImpl getFilteredExtraArgs dso self arg

      settlementFactory_settleBatchExtraObservers =
        settlementFactoryV2_publicAsset_settleBatchExtraObserversDefaultImpl dso

      settlementFactory_publicFetchImpl = publicFetchDefaultImpl this

    interface instance TransferEventsV2.EventLog for ExternalPartyAmuletRules where
      view = TransferEventsV2.EventLogView with
        admin = dso
        meta = emptyMetadata

      eventLog_holdingsChangeImpl = eventLog_holdingsChangeDefaultImpl dso


-- Legacy transfer commands
---------------------------

data ExternalPartyAmuletRules_CreateTransferCommandResult = ExternalPartyAmuletRules_CreateTransferCommandResult
  with
    transferCommandCid : ContractId TransferCommand
  deriving (Show, Eq)

-- | A contract tracking the number of completed TransferCommands per sender,
-- which is used to determine the nonces used in TransferCommands for deduplication.
template TransferCommandCounter
  with
    dso : Party
    sender : Party
    nextNonce : Int
  where
    signatory dso
    observer sender

instance HasCheckedFetch TransferCommandCounter ForOwner where
  contractGroupId TransferCommandCounter{..} =
    ForOwner with
      owner = sender
      dso

-- | Deprecated: The token standard transfer APIs now support 24h signing delays so this contract is no longer required.
--
-- One-time delegation to execute a transfer to the given receiver
-- for the given amount.
template TransferCommand
  with
    dso : Party
    sender : Party
    receiver : Party
    delegate : Party -- ^ The delegate that actually executes the transfer
    amount : Decimal
    expiresAt : Time -- ^ Expiry of the command until when TransferCommand_Send must be called
    nonce : Int
      -- ^ Expected nonce value to order and deduplicate concurrent transfers.
      -- Starts at 0 and the next value to use can then be read from TransferCommandCounter and the in-flight TransferCommand contracts.
    description : Optional Text
  where
    -- The DSO party is a signatory to make sure
    -- that the external signature
    -- is visible to the SVs.
    signatory sender, dso
    observer delegate

    choice TransferCommand_Send : TransferCommand_SendResult
      with
        context : PaymentTransferContext
        inputs : [TransferInput]
        -- The delegate is expected to select inputs that cover the amount being transferred, provided they exist.
        -- Otherwise the transfer will fail.
        transferPreapprovalCidO : Optional (ContractId TransferPreapproval)
        -- Unspecified if the transfer preapproval does not exist. The transfer command will get rejected in that case
        transferCounterCid : ContractId TransferCommandCounter
      controller delegate
      do transferCounter <- fetchChecked (ForOwner with owner = sender, dso) transferCounterCid
         if | transferCounter.nextNonce > nonce ->
              -- Fail but archive the TransferCommand
              pure TransferCommand_SendResult with
                result = TransferCommandResultFailure $ ITR_Other $ "Expected nonce " <> show nonce <> " is smaller than current counter " <> show transferCounter.nextNonce
                sender
                nonce
            | transferCounter.nextNonce < nonce ->
              -- Fail but don't archive the command so it can be retried
              abort ("Expected nonce " <> show nonce <> " is bigger than current counter " <> show transferCounter.nextNonce)
            | otherwise -> do
              -- Consider the nonce spent independent of whether funds get transferred or not.
              -- Thereby ensuring that transfer instructions get executed promptly.
              -- Clients are expected to retry in case their transfer fails unexpectedly.
              _ <- potentiallyUnsafeArchive transferCounterCid
              _ <- create transferCounter with nextNonce = transferCounter.nextNonce + 1
              case transferPreapprovalCidO of
                None ->
                  -- We cannot verify in Daml that the TransferPreapproval actually does not exist.
                  -- For now we trust the DSO delegate to chose correctly. The other SVs can monitor
                  -- this and change the delegate or even remove the SV if it does not operate
                  -- correctly.
                  pure TransferCommand_SendResult with
                    result = TransferCommandResultFailure $ ITR_Other $ "No TransferPreapproval for receiver " <> show receiver
                    sender
                    nonce
                Some transferPreapprovalCid -> do
                  -- Verify that receiver and DSO party match. We don't validate that the reeiver's provider matches
                 -- as changing that should be up to the receiver and not require the sender to resign.
                  _ <- fetchChecked (ForOwner with owner = receiver, dso) transferPreapprovalCid
                  assertWithinDeadline "TransferCommand.expiresAt" expiresAt
                  result <-
                    do
                      TransferPreapproval_SendResult result _meta <- exercise transferPreapprovalCid (TransferPreapproval_Send context inputs amount sender description)
                      pure (TransferCommandResultSuccess result)
                  pure TransferCommand_SendResult with
                    result
                    sender
                    nonce

    choice TransferCommand_Withdraw : TransferCommand_WithdrawResult
      controller sender
      do pure TransferCommand_WithdrawResult with
           sender
           nonce

    choice TransferCommand_Expire : TransferCommand_ExpireResult
      with
        p : Party
      controller p
      do require "Controller is a stakeholder" (p `elem` stakeholder this)
         assertDeadlineExceeded "TransferCommand.expiresAt" expiresAt
         pure TransferCommand_ExpireResult with
           sender
           nonce

instance HasCheckedFetch TransferCommand ForDso where
  contractGroupId TransferCommand{..} = ForDso dso

data TransferCommand_SendResult = TransferCommand_SendResult
  with
    result : TransferCommandResult
    sender : Party -- Returned to simplify tx log parsing
    nonce : Int -- Returned to simplify tx log parsing
  deriving (Show, Eq)

data TransferCommandResult
  = TransferCommandResultFailure with
      reason : InvalidTransferReason
  | TransferCommandResultSuccess with
      result : TransferResult
  deriving (Show, Eq)

data TransferCommand_WithdrawResult = TransferCommand_WithdrawResult
  with
    sender : Party -- Returned to simplify tx log parsing
    nonce : Int -- Returned to simplify tx log parsing
  deriving (Show, Eq)

data TransferCommand_ExpireResult = TransferCommand_ExpireResult
  with
    sender : Party -- Returned to simplify tx log parsing
    nonce : Int -- Returned to simplify tx log parsing
  deriving (Show, Eq)


-- Token standard transfer factory
----------------------------------

amulet_transferFactoryV1_transferImpl
  : ExternalPartyAmuletRules
  -> [Party]
  -> Api.Token.TransferInstructionV1.TransferFactory_Transfer
  -> Update Api.Token.TransferInstructionV1.TransferInstructionResult
amulet_transferFactoryV1_transferImpl this actors arg = do
  let Api.Token.TransferInstructionV1.TransferFactory_Transfer {expectedAdmin, transfer, extraArgs} = arg
  let dso = this.dso
  checkActors actors [[transfer.sender], [transfer.sender, transfer.receiver]]

  -- validate call to factory and retrieve context
  requireExpectedAdminMatch expectedAdmin dso

  -- == validate each field of the transfer specification ==
  -- sender: nothing to validate
  -- receiver: validate preapproval if given
  optPreapprovalCid <- lookupFromContextU @(ContractId TransferPreapproval) extraArgs.context transferPreapprovalContextKey
  forA_ optPreapprovalCid \preapprovalCid ->
    fetchChecked (ForOwner with dso; owner = transfer.receiver) preapprovalCid
  -- instrumentId:
  let expectedInstrumentId = amuletInstrumentId dso
  require
    ("Expected instrumentId " <> show expectedInstrumentId <> " matches actual instrumentId " <> show transfer.instrumentId)
    (expectedInstrumentId == transfer.instrumentId)
  -- amount:
  require "Amount must be positive" (transfer.amount > 0.0)
  -- requestedAt:
  assertDeadlineExceeded "transfer.requestedAt" transfer.requestedAt
  -- executeBefore: must be in the future, but not too far
  assertWithinDeadline "transfer.executeBefore" transfer.executeBefore
  (_, configState) <- getExternalPartyConfigStateFromChoiceContext dso arg.extraArgs.context
  let configAmulet = transferConfigAmuletFromExternalPartyConfigState configState
  let transferLifetime = transfer.executeBefore `subTime` transfer.requestedAt
  require' ("transferLifetime", transferLifetime) isLessOrEqualR
    ("tokenStandardMaxTTL", getTokenStandardMaxTTL configAmulet)
  -- inputHoldingCids: note that their detailed validation is done in the transfer itself
  require "At least one holding must be provided" (not $ null transfer.inputHoldingCids)
  -- meta: no extra account information allowed, as Amulet only supports basic accounts
  ensureNoAccountMeta "transfer" "sender" transfer.meta
  ensureNoAccountMeta "transfer" "receiver" transfer.meta

  case optPreapprovalCid of
    _ | transfer.receiver `elem` actors -> do
      -- self-transfer or sender+receiver authorized
      paymentContext <- unfeaturedPaymentContextFromChoiceContext dso arg.extraArgs.context
      inputs <- holdingToTransferInputs (ForOwner with dso; owner = transfer.sender) transfer.inputHoldingCids
      result <- executeExternalPartyTransfer dso paymentContext Transfer with
        sender = transfer.sender
        provider = transfer.sender
        inputs
        outputs = [ TransferOutput with
          receiver = transfer.receiver
          amount = transfer.amount
          receiverFeeRatio = 0.0
          lock = None
          meta = Some transfer.meta]
        beneficiaries = None
      pure Api.Token.TransferInstructionV1.TransferInstructionResult with
        senderChangeCids = toInterfaceContractId <$> optionalToList result.senderChangeAmulet
        output = Api.Token.TransferInstructionV1.TransferInstructionResult_Completed with
          receiverHoldingCids = createdAmuletToHolding <$> result.createdAmulets
        meta = fromOptional emptyMetadata result.meta

    None -> do
      -- prepare a two-step transfer
      let twoStepTransfer = standardTransferToTwoStepTransfer arg.transfer
      let requestedAt = arg.transfer.requestedAt
      paymentContext <- unfeaturedPaymentContextFromChoiceContext dso extraArgs.context
      (lockedAmulet, senderChangeCids, meta) <- prepareTwoStepTransfer twoStepTransfer requestedAt arg.transfer.inputHoldingCids paymentContext
      -- create the transfer instruction tracking this locked amulet
      transferInstructionCid <- toInterfaceContractId <$> create AmuletTransferInstruction with
        transfer = arg.transfer with
          inputHoldingCids = [toInterfaceContractId lockedAmulet] -- report the locked holding backing the transfer
        lockedAmulet
      -- return result
      pure Api.Token.TransferInstructionV1.TransferInstructionResult with
        senderChangeCids
        output = Api.Token.TransferInstructionV1.TransferInstructionResult_Pending
          with
            transferInstructionCid
        meta

    Some preapprovalCid -> do
      -- use a payment context with featuring so the preapproval provider can be featured
      paymentContext <- externalPartyTransferFromChoiceContext dso extraArgs.context
      -- execute a direct transfer
      inputs <- holdingToTransferInputs (ForOwner with dso; owner = transfer.sender) transfer.inputHoldingCids
      result <- exercise preapprovalCid TransferPreapproval_SendV2
        with
          sender = transfer.sender
          context = paymentContext
          inputs
          amount = transfer.amount
          description =
            -- TODO(tech-debt): remove this once we are sure everybody parses the metadata in the `TransferEventsV2.EventLog_HoldingsChange` and the reason field is no longer needed
            TextMap.lookup reasonMetaKey transfer.meta.values
          meta = Some transfer.meta

      -- return result
      pure Api.Token.TransferInstructionV1.TransferInstructionResult with
        senderChangeCids = toInterfaceContractId <$> optionalToList result.result.senderChangeAmulet
        output = Api.Token.TransferInstructionV1.TransferInstructionResult_Completed with
          receiverHoldingCids = createdAmuletToHolding <$> result.result.createdAmulets
        meta = result.meta


-- Token standard allocation factories
--------------------------------------

-- | Create a V2 allocation
amulet_allocationFactoryV2_allocateImpl
  : ExternalPartyAmuletRules
  -> ContractId V2.AllocationFactory
  -> V2.AllocationFactory_Allocate
  -> Update V2.AllocationInstructionResult
amulet_allocationFactoryV2_allocateImpl externalAmuletRules _self arg = do
  let netTransferAmount = netAmuletCreditAmount arg.allocation.authorizer arg.allocation.transferLegSides
  outputFundingAmount <- validateAmuletNextIterationFunding arg.allocation.nextIterationFunding
  let requiredFundingAmount = outputFundingAmount - netTransferAmount
  (lockedAmulet, senderChangeCids, expiresAt, meta) <-
    amulet_allocationFactoryV2_allocateImplCore externalAmuletRules arg requiredFundingAmount
  allocationCid <- toInterfaceContractId <$> create AmuletAllocationV2 with
    settlement = arg.settlement
    allocation = arg.allocation
    lockedAmulet
    expiresAt
    createdAt = arg.requestedAt
    numIterations = 0
  pure V2.AllocationInstructionResult with
    authorizerChangeCids = TextMap.fromList [(amuletInstrumentIdName, map upcast senderChangeCids)]
    output = V2.AllocationInstructionResult_Completed with allocationCid
    meta

-- | Core of the V2 allocation creation, which is used for both V1 and V2 factories.
amulet_allocationFactoryV2_allocateImplCore
  : ExternalPartyAmuletRules
  -> V2.AllocationFactory_Allocate
  -> Decimal
  -> Update (Optional (ContractId LockedAmulet), [ContractId V1.Holding], Time, Metadata)
amulet_allocationFactoryV2_allocateImplCore externalAmuletRules arg fundingAmount = do
  let dso = externalAmuletRules.dso
  let (V2.AllocationFactory_Allocate with settlement, allocation, requestedAt, inputHoldingCids, extraArgs, actors) = arg

  -- We are using an unfeatured payment context, as the locking to self should not be featured.
  paymentContext <- unfeaturedPaymentContextFromChoiceContext dso extraArgs.context

  -- check actors
  ensureBasicAccount "allocation.authorizer" allocation.authorizer
  let authorizer = accountPrincipal dso allocation.authorizer
  checkActors actors [[authorizer]]

  -- == validate each field of the requested allocation

  -- settlement.executors: no check
  -- settlement.id: no check
  -- settlement.cid: no check
  -- settlement.meta: no check

  -- allocation.settlementDeadline:
  whenSome allocation.settlementDeadline \d -> do
    assertWithinDeadline "Allocation.settlementDeadline" d

  -- allocation.admin:
  requireMatchExpected ("allocation.admin", allocation.admin) dso
  -- allocation.authorizer: checked above as part of actors
  -- allocation.transferLegSides:
  let transferLegSides = allocation.transferLegSides
  unless (isSome allocation.nextIterationFunding) $
    require' ("transferLegSides", transferLegSides) (notR isEqualR) ("empty list", [])
  AmuletAllocationV2.validateAmuletTransferLegSides transferLegSides

  -- allocation.nextIterationFunding: validated `amulet_allocationFactoryV2_allocateImpl`
  -- allocation.committed: nothing to validate
  -- allocation.meta: check no redundant account information
  ensureNoAccountMeta "allocation" "authorizer" allocation.meta

  -- arg.requestedAt (of the allocation instruction itself):
  assertDeadlineExceeded "requestedAt" requestedAt
  -- arg.inputHoldingCids: validated by prepareTwoStepTransfer if funidng is required
  -- arg.extraArgs: no check other than what's done when retrieving reference data
  -- arg.actors: checked above

  -- compute the allocation expiry time
  (_, configState) <- getExternalPartyConfigStateFromChoiceContext dso arg.extraArgs.context
  let configAmulet = transferConfigAmuletFromExternalPartyConfigState configState
  expiresAt <- computeAllocationExpiry configAmulet requestedAt allocation.settlementDeadline

  -- create locked amulet if required
  if fundingAmount <= 0.0
  then do
    -- return input cids as change, so they can be reused on chaining
    return (None, map downcast inputHoldingCids, expiresAt, emptyMetadata)
  else do
    require "At least one input holding must be provided for allocations that require funding" (not (null inputHoldingCids))
    -- lock the funds
    let twoStepTransfer = TwoStepTransfer with
          dso
          sender = authorizer
          amount = fundingAmount
          lockContext = AmuletAllocationV1.mkAllocationLockContext (downcast settlement)
          transferBefore = expiresAt
          transferBeforeDeadline = "allocation.expiresAt"
          -- Minor hack: we use the authorizer for receiver and provider as these fields are irrlevant
          -- for preparing the two-step transfer .
          receiver = authorizer
          provider = authorizer
          allowFeaturing = False
    (la, cids, meta) <- prepareTwoStepTransfer twoStepTransfer arg.requestedAt (map downcast inputHoldingCids) paymentContext
    return (Some la, cids, expiresAt, meta)

-- | Create a V1 allocation
amulet_allocationFactoryV1_allocateImpl
  : ExternalPartyAmuletRules
  -> ContractId V1.AllocationFactory
  -> V1.AllocationFactory_Allocate
  -> Update V1.AllocationInstructionResult
amulet_allocationFactoryV1_allocateImpl externalAmuletRules _self arg = do
  -- validate call to factory and retrieve context
  let dso = externalAmuletRules.dso
  requireExpectedAdminMatch arg.expectedAdmin dso

  -- validate allocateBefore
  -- Note: we allow `allocateBefore == settleBefore` as this simplifies defaulting when downcasting
  -- from V2, and is not less practical than requiring allocateBefore < settleBefore, which in the worst case
  -- only gives an extra microsecond for the settlement to complete.
  let settlement = arg.allocation.settlement
  assertWithinDeadline "allocation.settlement.allocateBefore" settlement.allocateBefore
  require' ("allocation.settlement.allocateBefore", settlement.allocateBefore) isLessOrEqualR
    ("allocation.settlement.settleBefore", settlement.settleBefore)

  -- call V2 body with explicitly computed funding amount, which matters
  -- as V2 uses net amounts and V1 uses gross amounts, which are different for self-transfers
  let fundingAmount = arg.allocation.transferLeg.amount
  let argV2 = V2.AllocationFactory_Allocate with
        settlement = upcast arg.allocation.settlement
        allocation = upcast arg.allocation
        requestedAt = arg.requestedAt
        inputHoldingCids = map upcast arg.inputHoldingCids
        actors = [arg.allocation.transferLeg.sender]
        extraArgs = arg.extraArgs
  (optLockedAmulet, senderChangeCids, expiresAt, meta) <-
    amulet_allocationFactoryV2_allocateImplCore externalAmuletRules argV2 fundingAmount

  -- create the amulet allocation
  let lockedAmulet = fromSomeNote "unexpected: no locked amulet created" optLockedAmulet
  allocationCid <- toInterfaceContractId <$> create AmuletAllocation with
    allocation = arg.allocation
    lockedAmulet
    expiresAt = Some expiresAt
  pure V1.AllocationInstructionResult with
    senderChangeCids
    output = V1.AllocationInstructionResult_Completed with allocationCid
    meta


-- Utilities
------------

requireExpectedAdminMatch : Party -> Party -> Update ()
requireExpectedAdminMatch expected actual =   require ("Expected admin " <> show expected <> " matches actual admin " <> show actual) (expected == actual)

instance HasCheckedFetch ExternalPartyAmuletRules ForDso where
  contractGroupId ExternalPartyAmuletRules{..} = ForDso dso
