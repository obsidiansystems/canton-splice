mkAllocationFactory_AllocateV1
  : V1.RegistryApi api => api -> V1.AllocationSpecification -> Script TSABatch
mkAllocationFactory_AllocateV1 registry allocation = do
    now <- getTime
    enrichedChoice <- V1.getAllocationFactory registry V1.AllocationFactory_Allocate with
      expectedAdmin = admin
      allocation
      inputHoldingCids = []
      requestedAt = now
      extraArgs = emptyExtraArgs
    let action = BatchingUtilityV2.TSA_AllocationFactory_AllocateV1 BatchingUtilityV2.ChoiceCall with
          cid = coerceContractId enrichedChoice.factoryCid
          arg = enrichedChoice.arg
    pure TSABatch with
      actions = [action]
      accountsAndInstruments = Set.singleton (senderAccount, instrumentId)
      disclosures = enrichedChoice.disclosures
  where
    instrumentId = TSU.upcast allocation.transferLeg.instrumentId
    admin = instrumentId.admin
    senderAccount = TSU.accountFromMeta allocation.transferLeg.sender "sender" allocation.transferLeg.meta

mkAllocationFactory_AllocateV2
  : V2.RegistryApi api => api -> Party -> V2.SettlementInfo -> V2.AllocationSpecification -> Script TSABatch
mkAllocationFactory_AllocateV2 registryV2 actor settlement allocation = do
  now <- getTime
  enrichedChoice <- V2.getAllocationFactory registryV2 V2.AllocationFactory_Allocate with
    settlement
    allocation
    inputHoldingCids = []
    requestedAt = now
    extraArgs = emptyExtraArgs
    actors = [actor]
  let action = BatchingUtilityV2.TSA_AllocationFactory_AllocateV2 BatchingUtilityV2.ChoiceCall with
        cid = TSU.toAnyContractId enrichedChoice.factoryCid
        arg = enrichedChoice.arg
  pure TSABatch with
    actions = [action]
    accountsAndInstruments = Set.fromList $
      do
        leg <- allocation.transferLegSides
        let iid = V2.InstrumentId with
              id = leg.instrumentId
              admin = allocation.admin
        pure (allocation.authorizer, iid)
      <>
      do
        funding <- optionalToList allocation.nextIterationFunding
        id <- TSU.textMapKeys funding
        pure (allocation.authorizer, V2.InstrumentId with id, admin = allocation.admin)
    disclosures = enrichedChoice.disclosures

mkAllocation_WithdrawV2 : MultiRegistry.MultiRegistry -> Party -> (ContractId V2.Allocation, V2.AllocationView) -> Script TSABatch
mkAllocation_WithdrawV2 registries actor (allocCid, allocView) = do
  registry <- MultiRegistry.getRegistryApiV2 registries allocView.allocation.admin
  context <- V2.getAllocation_WithdrawContext registry allocCid emptyMetadata
  let withdrawRequest = BatchingUtilityV2.TSA_Allocation_WithdrawV2 BatchingUtilityV2.ChoiceCall with
        cid = TSU.toAnyContractId allocCid
        arg = V2.Allocation_Withdraw with
          extraArgs = ExtraArgs with
            context = context.choiceContext
            meta = emptyMetadata
          actors = [actor]
  pure TSABatch with
    actions = [withdrawRequest]
    accountsAndInstruments = mempty
    disclosures = context.disclosures

mkAllocationRequest_AcceptV2 : Party -> ContractId V2.AllocationRequest -> Script TSABatch
mkAllocationRequest_AcceptV2 actor reqCid = do
  let acceptRequest = BatchingUtilityV2.TSA_AllocationRequest_AcceptV2 BatchingUtilityV2.ChoiceCall with
        cid = TSU.toAnyContractId reqCid
        arg = V2.AllocationRequest_Accept with
          extraArgs = emptyExtraArgs
          actors = [actor]
  pure TSABatch with
    actions = [acceptRequest]
    accountsAndInstruments = mempty
    disclosures = mempty

mkAllocationRequest_RejectV2 : Party -> ContractId V2.AllocationRequest -> Script TSABatch
