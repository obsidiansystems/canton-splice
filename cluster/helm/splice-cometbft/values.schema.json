{
  "$schema": "http://json-schema.org/schema#",
  "type": "object",
  "required": [
    "imageName"
  ],
  "properties": {
    "securityContexts": {
      "type": "object",
      "properties": {
        "pod": {
          "type": "object"
        },
        "containers": {
          "type": "object",
          "properties": {
            "cometbft": {
              "type": "object"
            }
          },
          "required": ["cometbft"]
        }
      },
      "required": ["pod", "containers"]
    },
    "imageName": {
      "type": "string"
    },
    "serviceAccountName": {
      "type": "string"
    },
    "genesis": {
      "type": "object",
      "required": [
        "chainId"
      ],
      "properties": {
        "imagePullPolicy": {
          "type": "string"
        },
        "chainId": {
          "type": "string"
        },
        "chainIdSuffix": {
          "type": "string"
        }
      }
    }
  }
}
